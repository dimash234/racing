ssword) =>\r\n    signInWithEmailAndPassword(auth, email, password);\r\n\r\n  const logout = () => signOut(auth);\r\n\r\n  return { user, loading, register, login, logout };\r\n}"],"mappings":"AAAA,OAASA,QAAQ,CAAEC,SAAS,KAAQ,OAAO,CAC3C,OACEC,8BAA8B,CAC9BC,0BAA0B,CAC1BC,OAAO,CACPC,kBAAkB,CAClBC,aAAa,KACR,eAAe,CACtB,OAASC,IAAI,KAAQ,UAAU,CAE/B,MAAO,SAAS,CAAAC,OAAOA,CAAA,CAAG,CACxB,KAAM,CAACC,IAAI,CAAEC,OAAO,CAAC,CAAGV,QAAQ,CAAC,IAAI,CAAC,CACtC,KAAM,CAACW,OAAO,CAAEC,UAAU,CAAC,CAAGZ,QAAQ,CAAC,IAAI,CAAC,CAE5CC,SAAS,CAAC,IAAM,CACd,KAAM,CAAAY,KAAK,CAAGR,kBAAkB,CAACE,IAAI,CAAGO,CAAC,EAAK,CAC5CJ,OAAO,CAACI,CAAC,CAAC,CACVF,UAAU,CAAC,KAAK,CAAC,CACnB,CAAC,CAAC,CACF,MAAO,CAAAC,KAAK,CACd,CAAC,CAAE,EAAE,CAAC,CAEN,KAAM,CAAAE,QAAQ,CAAG,KAAAA,CAAOC,KAAK,CAAEC,QAAQ,CAAEC,IAAI,GAAK,CAChD,KAAM,CAAAC,IAAI,CAAG,KAAM,CAAAjB,8BAA8B,CAACK,IAAI,CAAES,KAAK,CAAEC,QAAQ,CAAC,CACxE,KAAM,CAAAX,aAAa,CAACa,IAAI,CAACV,IAAI,CAAE,CAAEW,WAAW,CAAEF,IAAK,CAAC,CAAC,CACrD,MAAO,CAAAC,IAAI,CAACV,IAAI,CAClB,CAAC,CAED,KAAM,CAAAY,KAAK,CAAGA,CAACL,KAAK,CAAEC,QAAQ,GAC5Bd,0BAA0B,CAACI,IAAI,CAAES,KAAK,CAAEC,QAAQ,CAAC,CAEnD,KAAM,CAAAK,MAAM,CAAGA,CAAA,GAAMlB,OAAO,CAACG,IAAI,CAAC,CAElC,MAAO,CAAEE,IAAI,CAAEE,OAAO,CAAEI,QAAQ,CAAEM,KAAK,CAAEC,MAAO,CAAC,CACnD","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}